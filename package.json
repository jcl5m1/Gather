{
  "name": "gather",
  "version": "1.0.0",
  "description": "Unity-based resource gathering automation game that spans multple planets with realistic orbital mechanics and energy requirements",
  "main": "index.js",
  "scripts": {
    "build": "webpack --config webpack.game.config.js",
    "start": "webpack serve --config webpack.game.config.js",
    "build:game": "webpack --config webpack.game.config.js",
    "start:game": "webpack serve --config webpack.game.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:moon": "webpack --config experimental/moonOrbitSim/webpack.config.js",
    "start:moon": "webpack serve --config experimental/moonOrbitSim/webpack.config.js",
    "build:mine": "webpack --config experimental/mineGather/webpack.config.js",
    "start:mine": "webpack serve --config experimental/mineGather/webpack.config.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "marked": "^12.0.0",
    "safe-units": "^2.0.1",
    "three": "^0.169.0",
    "three-orbitcontrols": "^2.110.2",
    "typescript": "^5.6.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/three": "^0.169.0",
    "@types/uuid": "^10.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "playwright": "^1.59.1",
    "ts-loader": "^9.5.1",
    "vitest": "^4.1.6",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcl5m1/Gather.git"
  },
